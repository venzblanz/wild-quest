<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state: light maroon tint fill -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <solid android:color="#1A8B0000" />
            <stroke
                android:width="1.5dp"
                android:color="@color/dark_maroon" />
        </shape>
    </item>

    <!-- Default state: no fill, just border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <solid android:color="@color/dark_maroon" />
            <stroke
                android:width="1.5dp"
                android:color="@color/black" />
        </shape>
    </item>



</selector>