<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wildquestbg"
    tools:context=".screens.main.soloreview.lobby.custom.prep.SoloCustomPrepActivity"
    android:orientation="vertical">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/contents"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="25dp"
                android:layout_marginRight="20dp"
                android:padding="20dp"
                android:elevation="20dp"
                android:background="@drawable/rounded_corners"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="10dp"
                    android:text="Set up your Questions"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:fontFamily="@font/irishgrover"
                    android:textAlignment="center" />

                <RadioGroup
                    android:id="@+id/questionTypeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="5dp">

                    <RadioButton
                        android:id="@+id/rbMultipleChoice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/black"
                        style="@style/MaroonRadioButton"
                        android:buttonTint="@color/maroon"
                        android:text="Multiple Choice"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rbIdentification"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        style="@style/MaroonRadioButton"
                        android:buttonTint="@color/maroon"
                        android:layout_weight="1"
                        android:text="Identification" />

                </RadioGroup>
                <FrameLayout
                    android:id="@+id/questionFormContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Saved Questions"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/irishgrover"
                    android:layout_marginTop="5dp" />

                <ListView
                    android:id="@+id/questionListView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="5dp" />

                <LinearLayout
                    android:id="@+id/startBtn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:background="@drawable/rounded_clickable_linear"
                    android:layout_marginTop="16dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/btn_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:fontFamily="@font/irishgrover"
                        android:text="Start Review"/>

                </LinearLayout>

            </LinearLayout>
            <!-- Footer Logo -->
            <include layout="@layout/partial_footer_logo_home_button" />
        </LinearLayout>

    </ScrollView>



</LinearLayout>